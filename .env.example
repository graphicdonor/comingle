# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel (/admin) — single shared password, no per-admin accounts
ADMIN_SECRET=

# Dev-mode auth bypass (localStorage-backed, no real Supabase writes) — see src/lib/dev-auth.ts
NEXT_PUBLIC_DEV_MODE=false
NEXT_PUBLIC_DEV_PHONE=
NEXT_PUBLIC_DEV_OTP=

# Content moderation — see MODERATION.md
# Without this set, all moderated content fails closed to hold_for_review
# rather than being allowed through.
OPENAI_API_KEY=
MODERATION_BLOCK_THRESHOLD=0.85
MODERATION_REVIEW_THRESHOLD=0.5
AUTO_BAN_VIOLATION_COUNT=3
AUTO_BAN_WINDOW_DAYS=30
